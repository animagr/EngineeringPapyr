{"data":{"version":20260313,"config":{"mathCellConfig":{"symbolicOutput":false,"showIntermediateResults":false,"formatOptions":{"notation":"auto","precision":5,"lowerExp":-3,"upperExp":5}},"simplifySymbolicExpressions":true,"convertFloatsToFractions":true,"customBaseUnits":{"mass":"kg","length":"m","time":"s","current":"A","temperature":"K","luminous_intensity":"cd","amount_of_substance":"mol","force":"N","area":"m^2","volume":"m^3","energy":"J","power":"W","pressure":"Pa","charge":"C","capacitance":"F","electric_potential":"V","resistance":"ohm","inductance":"H","conductance":"S","magnetic_flux":"Wb","magnetic_flux_density":"T","angle":"rad","information":"b"},"fluidConfig":{"fluid":"Water","incompMixConc":0.5,"customMixture":[{"fluid":"R32","moleFraction":0.697615},{"fluid":"R125","moleFraction":0.302385}]}},"cells":[{"type":"documentation","id":0,"json":{"ops":[{"attributes":{"size":"large","bold":true},"insert":"Power Supply Topology Reference Calculator"},{"insert":"\n"}]}},{"type":"documentation","id":98,"json":{"ops":[{"attributes":{"bold":true},"insert":"Topology Selection Guide"},{"insert":"\n\n"},{"attributes":{"bold":true},"insert":"Flyback"},{"insert":" (<150 W, Low Cost)\nApplications: Cell phone chargers (<10 W), Notebook adapters (<100 W), CRT power supplies (<150 W)\nBenefits: Ease of implementation, Well-documented, Wide mains operation, Large controller offer\nNegatives: High peak currents, Leakage inductance difficult to manage, Poor EMI signature, Large output ripple\n\n"},{"attributes":{"bold":true},"insert":"Single-Switch Forward"},{"insert":" (<300 W, Moderate Cost)\nApplications: ATX power supplies (<250 W), DC-DC converters for telecom\nBenefits: Good cross-regulation with coupled inductors, Good EMI signature, Low ac content\nNegatives: Stress on power MOSFET, Difficult on wide mains, Requires transformer reset, D clamped to 50%\n\n"},{"attributes":{"bold":true},"insert":"Two-Switch Forward"},{"insert":" (100-500 W, Moderate Cost)\nApplications: ATX power supplies (<500 W), DC-DC for telecom, Servers (<500 W)\nBenefits: Good cross-regulation, Good EMI, MOSFET stress clamped to Vin\nNegatives: Difficult on wide mains, Requires transformer reset, D clamped to 50%, Requires high-side drive\n\n"},{"attributes":{"bold":true},"insert":"Half-Bridge"},{"insert":" (100-500 W, Moderate Cost)\nApplications: ATX power supplies (<500 W), DC-DC for telecom\nBenefits: Good cross-regulation, Good EMI, MOSFET stress clamped to Vin, D < 100%\nNegatives: Difficult on wide mains, Requires high-side drive, Cannot easily work with current mode\n\n"},{"attributes":{"bold":true},"insert":"Half-Bridge LLC"},{"insert":" (<500 W, Moderate Cost)\nApplications: Medical power supplies, LCD or plasma TVs\nBenefits: Excellent EMI signature, Can work in no load, Smooth waveforms / ZVS possible\nNegatives: High-side drive, Large rms content, Narrow mains operation, Dangerous short-circuit\n\n"},{"attributes":{"bold":true},"insert":"Full-Bridge"},{"insert":" (>500 W, High Cost)\nApplications: Server and mainframe power supplies, High-power DC-DC for telecom\nBenefits: Good cross-regulation, Resonant operation via phase shift, Good EMI, MOSFET stress clamped to Vin\nNegatives: Difficult on wide mains, Requires two high-side drive circuits, Four MOSFETs to drive\n\n"},{"attributes":{"bold":true},"insert":"Push-Pull"},{"insert":" (<200 W, Moderate Cost)\nApplications: DC-DC converters\nBenefits: MOSFETs control is ground-referenced, D < 100%\nNegatives: Voltage stress of 2*Vin, Center-tapped primary\n"}]}},{"type":"documentation","id":99,"json":{"ops":[{"attributes":{"bold":true},"insert":"Selection by Input Voltage and Output Power"},{"insert":"\n\nUniversal (90-264 VAC), Po < 150 W, Iload < 10 A → Flyback, Forward\nUniversal (90-264 VAC), Po < 150 W, Iload > 10 A → Forward\nUniversal (90-264 VAC), 150 W < Po < 350 W → Two-Switch Forward, Half-Bridge, Push-Pull\nUniversal (90-264 VAC), Po < 500 W → Half-Bridge, Push-Pull\nVin > 350 VDC, Po < 750 W → Half-Bridge\nVin < 200 VDC, Po < 500 W → Push-Pull\nVin > 350 VDC, 500 < Po < 1000 W → Full-Bridge\nVin > 350 VDC, Po > 1000 W → ZVT Full-Bridge\nVin > 350 VDC, Po > 2000 W → Parallel/Interleaved ZVT Full-Bridge\n"}]}},{"type":"documentation","id":100,"json":{"ops":[{"attributes":{"bold":true},"insert":"Control Methods"},{"insert":"\n\nVoltage-Mode | Average OC | Slow Response | Forward-Mode\nVoltage-Mode | Pulse-by-Pulse OC | Slow Response | Forward-Mode\nCurrent-Mode | Intrinsic OC | Rapid Response | Boost-Mode\nCurrent-Mode | Hysteretic OC | Rapid Response | Boost & Forward-Mode\nHysteretic Voltage | Average OC | Slow Response | Boost & Forward-Mode\n"}]}},{"type":"documentation","id":1,"json":{"ops":[{"attributes":{"bold":true},"insert":"Input Parameters"},{"insert":"\n"}]}},{"type":"math","id":2,"latex":"V_{in}=48","config":null,"annotation":"Input Voltage [V]"},{"type":"math","id":3,"latex":"V_{out}=12","config":null,"annotation":"Output Voltage [V]"},{"type":"math","id":101,"latex":"V_{outb}=100","config":null,"annotation":"Boost Output Voltage [V]"},{"type":"math","id":4,"latex":"V_{f}=0.5","config":null,"annotation":"Diode Forward Voltage [V]"},{"type":"documentation","id":5,"json":{"ops":[{"attributes":{"bold":true},"insert":"Buck"},{"insert":"\n"}]}},{"type":"math","id":6,"latex":"D_{bk}=\\frac{V_{out}+V_{f}}{V_{in}+V_{f}}=","config":null,"annotation":"Duty Cycle"},{"type":"math","id":7,"latex":"V_{Qbk}=V_{in}+V_{f}=","config":null,"annotation":"Q1 FET Voltage [V]"},{"type":"math","id":8,"latex":"V_{Dbk}=V_{in}=","config":null,"annotation":"D1 Diode Voltage [V]"},{"type":"documentation","id":9,"json":{"ops":[{"attributes":{"bold":true},"insert":"Synchronous Buck"},{"insert":"\n"}]}},{"type":"math","id":10,"latex":"D_{sb}=\\frac{V_{out}}{V_{in}}=","config":null,"annotation":"Duty Cycle"},{"type":"math","id":11,"latex":"V_{Q1sb}=V_{in}=","config":null,"annotation":"Q1 FET Voltage [V]"},{"type":"math","id":12,"latex":"V_{Q2sb}=V_{in}=","config":