":108,"json":{"ops":[{"insert":"Switch Utilization U(D) = (1-D)*sqrt(D)\nMax U(D) = 2/(3*sqrt(3))\nMax U(D) occurs at D = 1/3\n"}]}},{"type":"documentation","id":51,"json":{"ops":[{"attributes":{"bold":true},"insert":"Two-Switch Flyback"},{"insert":"\n"},{"attributes":{"width":"292"},"insert":{"image":"data:image/png;base64,"}},{"insert":"\n"}]}},{"type":"math","id":52,"latex":"D_{fl2}=\\frac{\\left(V_{out}+V_{f}\\right)\\cdot N_{p}}{V_{in}\\cdot N_{s}+\\left(V_{out}+V_{f}\\right)\\cdot N_{p}}=","config":null,"annotation":"Duty Cycle"},{"type":"math","id":53,"latex":"V_{Qfl2}=\\frac{V_{in}\\cdot N_{s}+\\left(V_{out}+V_{f}\\right)\\cdot N_{p}}{2\\cdot N_{s}}=","config":null,"annotation":"Q1 FET Voltage [V]"},{"type":"math","id":54,"latex":"V_{Dfl2}=V_{out}+\\frac{V_{in}\\cdot N_{s}}{N_{p}}=","config":null,"annotation":"D1 Diode Voltage [V]"},{"type":"documentation","id":55,"json":{"ops":[{"attributes":{"bold":true},"insert":"Active Clamp Forward"},{"insert":"\n"},{"attributes":{"width":"385"},"insert":{"image":"data:image/png;base64,"}},{"insert":"\n"}]}},{"type":"math","id":56,"latex":"D_{acf}=\\frac{\\left(V_{out}+V_{f}\\right)\\cdot N_{p}}{V_{in}\\cdot N_{s}}=","config":null,"annotation":"Duty Cycle"},{"type":"math","id":57,"latex":"V_{Qacf}=\\frac{V_{in}}{1-D_{acf}}=","config":null,"annotation":"Q1 FET Voltage [V]"},{"type":"math","id":58,"latex":"V_{D1acf}=\\frac{V_{clamp}\\cdot N_{s}}{N_{p}}-V_{f}=","config":null,"annotation":"D1 Diode Voltage [V]"},{"type":"math","id":59,"latex":"V_{D2acf}=\\frac{V_{in}\\cdot N_{s}}{N_{p}}-V_{f}=","config":null,"annotation":"D2 Diode Voltage [V]"},{"type":"documentation","id":109,"json":{"ops":[{"insert":"n_1=n_2\nSwitch Utilization U(D) = 1/2*sqrt(D)\nMax U(D) = 1/(2*sqrt(2))\nMax U(D) occurs at D = 1/2\n"}]}},{"type":"documentation","id":60,"json":{"ops":[{"attributes":{"bold":true},"insert":"Single-Switch Forward"},{"insert":"\n"},{"attributes":{"width":"386"},"insert":{"image":"data:image/png;base64,"}},{"insert":"\n"}]}},