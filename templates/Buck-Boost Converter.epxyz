{"data":{"version":20260313,"config":{"mathCellConfig":{"symbolicOutput":false,"showIntermediateResults":false,"formatOptions":{"notation":"auto","precision":5,"lowerExp":-3,"upperExp":5}},"simplifySymbolicExpressions":true,"convertFloatsToFractions":true,"customBaseUnits":{"mass":"kg","length":"m","time":"s","current":"A","temperature":"K","luminous_intensity":"cd","amount_of_substance":"mol","force":"N","area":"m^2","volume":"m^3","energy":"J","power":"W","pressure":"Pa","charge":"C","capacitance":"F","electric_potential":"V","resistance":"ohm","inductance":"H","conductance":"S","magnetic_flux":"Wb","magnetic_flux_density":"T","angle":"rad","information":"b"},"fluidConfig":{"fluid":"Water","incompMixConc":0.5,"customMixture":[{"fluid":"R32","moleFraction":0.697615},{"fluid":"R125","moleFraction":0.302385}]}},"cells":[{"type":"documentation","id":0,"json":{"ops":[{"attributes":{"size":"large","bold":true},"insert":"Buck-Boost (Inverting) Converter Design"},{"insert":"\nOutput voltage polarity is inverted. All values of Vout are magnitude.\n"}]}},{"type":"documentation","id":1,"json":{"ops":[{"attributes":{"bold":true},"insert":"Input Parameters"},{"insert":"\n"}]}},{"type":"math","id":2,"latex":"V_{in}=12","config":null,"annotation":"Typical Input Voltage [V]"},{"type":"math","id":3,"latex":"V_{inmin}=9","config":null,"annotation":"Min Input Voltage [V]"},{"type":"math","id":4,"latex":"V_{out}=15","config":null,"annotation":"Output Voltage Magnitude [V]"},{"type":"math","id":5,"latex":"I_{outmax}=0.5","config":null,"annotation":"Max Output Current [A]"},{"type":"math","id":6,"latex":"f_{s}=500000","config":null,"annotation":"Switching Frequency [Hz]"},{"type":"math","id":7,"latex":"\\eta=0.8","config":null,"annotation":"Estimated Efficiency"},{"type":"math","id":8,"latex":"V_{F}=0.5","config":null,"annotation":"Diode Forward Voltage [V]"},{"type":"math","id":9,"latex":"V_{FB}=0.8","config":null,"annotation":"Feedback Voltage [V]"},{"type":"math","id":10,"latex":"I_{FB}=0.000001","config":null,"annotation":"Feedback Bias Current [A]"},{"type":"math","id":11,"latex":"R_{ESR}=0.02","config":null,"annotation":"Output Cap ESR [ohm]"},{"type":"math","id":12,"latex":"V_{rip}=0.1","config":null,"annotation":"Output Voltage Ripple [V]"},{"type":"documentation","id":13,"json":{"ops":[{"attributes":{"bold":true},"insert":"Duty Cycle"},{"insert":"\n"}]}},{"type":"math","id":14,"latex":"D=\\frac{V_{out}}{V_{inmin}\\cdot\\eta+V_{out}}=","config":null,"annotation":"Duty Cycle"},{"type":"documentation","id":15,"json":{"ops":[{"attributes":{"bold":true},"insert":"Inductor Selection"},{"insert":"\n"}]}},{"type":"math","id":16,"latex":"I_{rip}=0.3\\cdot I_{outmax}\\cdot\\frac{V_{in}+V_{out}}{V_{in}}=","config":null,"annotation":"Inductor Ripple Current [A]"},{"type":"math","id":17,"latex":"L=\\frac{V_{in}\\cdot V_{out}}{I_{rip}\\cdot f_{s}\\cdot\\left(V_{in}+V_{out}\\right)}=","config":null,"annotation":"Inductance [H]"},{"type":"documentation","id":18,"json":{"ops":[{"attributes":{"bold":true},"insert":"Maximum Switch Current"},{"insert":"\n"}]}},{"type":"math","id":19,"latex":"I_{swmax}=\\frac{I_{rip}}{2}+\\frac{I_{outmax}}{1-D}=","config":null,"annotation":"Max Switch Current [A]"},{"type":"documentation","id":20,"json":{"ops":[{"attributes":{"bold":true},"insert":"Inductor & Switch Stress"},{"insert":"\n"}]}},{"type":"math","id":21,"latex":"I_{Lavg}=\\frac{I_{outmax}}{1-D}=","config":null,"annotation":"Avg Inductor Current [A]"},{"type":"math","id":22,"latex":"I_{Lpk}=I_{Lavg}+\\frac{I_{rip}}{2}=","config":null,"annotation":"Peak Inductor Current [A]"},{"type":"math","id":23,"latex":"I_{Lrms}=\\sqrt{I_{Lavg}^{2}+\\frac{I_{rip}^{2}}{12}}=","config":null,"annotation":"RMS Inductor Current [A]"},{"type":"math","id":24,"latex":"V_{sw}=V_{in}+V_{out}=","config":null,"annotation":"Switch/Diode Voltage Stress [V]"},{"type":"documentation","id":25,"json":{"ops":[{"attributes":{"bold":true},"insert":"Rectifier Diode Selection"},{"insert":"\n"}]}},{"