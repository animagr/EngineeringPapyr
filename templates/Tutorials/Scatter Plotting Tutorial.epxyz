{"data":{"version":20260414,"config":{"mathCellConfig":{"symbolicOutput":false,"formatOptions":{"notation":"auto","precision":15,"lowerExp":-3,"upperExp":5},"showIntermediateResults":false},"customBaseUnits":{"mass":"kg","length":"m","time":"s","current":"A","temperature":"K","luminous_intensity":"cd","amount_of_substance":"mol","force":"N","area":"m^2","volume":"m^3","energy":"J","power":"W","pressure":"Pa","charge":"C","capacitance":"F","electric_potential":"V","resistance":"ohm","inductance":"H","conductance":"S","magnetic_flux":"Wb","magnetic_flux_density":"T","angle":"rad","information":"b"},"simplifySymbolicExpressions":true,"convertFloatsToFractions":true,"fluidConfig":{"fluid":"Water","incompMixConc":0.5,"customMixture":[{"fluid":"R32","moleFraction":0.697615},{"fluid":"R125","moleFraction":0.302385}]}},"cells":[{"type":"documentation","id":1,"json":{"ops":[{"insert":"In addition to the capability to easily plot user defined functions (see the "},{"attributes":{"link":"https://engineeringpaper.xyz/TxAftUqQCmXKNPX5XGBUy8"},"insert":"Plotting and Functions"},{"insert":" tutorial), EngineeringPaper.xyz now has the capability to plot scatter plots with one or more points. This capability takes advantage of the matrix and vector features that were recently added (see the "},{"attributes":{"link":"https://engineeringpaper.xyz/8pWM9yEqEPNntRBd6Jr9Sv"},"insert":"Matrices and Vectors"},{"insert":" tutorial). To create a scatter plot, create a query statement with two vectors separated by a comma following by an equals sign. See the plot cell below for an example of this notation. The vectors may be either column vectors or row vectors, they just need to have the same length.\n"}]}},{"type":"plot","id":3,"latexs":["\\begin{bmatrix}1\\\\ 2\\\\ 3\\\\ 4\\\\ 5\\end{bmatrix},\\begin{bmatrix}0.9\\\\ 1.3\\\\ 2.1\\\\ 2.9\\\\ 3.2\\end{bmatrix}="],"logX":false,"logY":false,"squareAspectRatio":false},{"type":"documentation","id":5,"json":{"ops":[{"insert":"Scatter plots may be combined with plots of functions as show in the following example:\n"}]}},{"type":"math","id":4,"latex":"y=x","config":null},{"type":"plot","id":7,"latexs":["\\begin{bmatrix}1\\\\ 2\\\\ 3\\\\ 4\\\\ 5\\end{bmatrix},\\begin{bmatrix}0.9\\\\ 1.3\\\\ 2.1\\\\ 2.9\\\\ 3.2\\end{bmatrix}=","y\\left(0\\le x\\le6\\right)="],"logX":false,"logY":false,"squareAspectRatio":false},{"type":"documentation","id":9,"json":{"ops":[{"insert":"A single point can be plotted by using a pair of scalar values instead of a pair of vectors as shown in the next example:\n"}]}},{"type":"plot","id":10,"latexs":["\\begin{bmatrix}1\\\\ 2\\\\ 3\\\\ 4\\\\ 5\\end{bmatrix},\\begin{bmatrix}0.9\\\\ 1.3\\\\ 2.1\\\\ 2.9\\\\ 3.2\\end{bmatrix}=","3,3.1="],"logX":false,"logY":false,"squareAspectRatio":false},{"type":"documentation","id":11,"json":{"ops":[{"insert":"The scatter plot can be plotted as lines instead of points by adding \"as lines\" after the pair of vectors as shown below:\n"}]}},{"type":"plot","id":12,"latexs":["\\begin{bmatrix}1\\\\ 2\\\\ 3\\\\ 4\\\\ 5\\end{bmatrix},\\begin{bmatrix}0.9\\\\ 1.3\\\\ 2.1\\\\ 2.9\\\\ 3.2\\end{bmatrix}as\\:lines="],"logX":false,"logY":false,"squareAspectRatio":false},{"type":"documentation","id":13,"json":{"ops":[{"insert":"Units are supported as well and the units for the plot axes can be specified by placing the desired x and y units after the equals sign separated by a comma as shown below:\n"}]}},{"type":"plot","id":14,"latexs":["\\begin{bmatrix}1\\\\ 2\\\\ 3\\end{bmatrix}\\cdot1\\left\\lbrack m\\right\\rbrack,\\begin{bmatrix}360\\\\ 430\\\\ 500\\end{bmatrix}\\cdot1\\left\\lbrack s\\right\\rbrack=\\:\\left\\lbrack mm\\right\\rbrack,\\left\\lbrack min\\right\\rbrack"],"logX":false,"logY":false,"squareAspectRatio":false},{"type":"documentation","id":15,"json":{"ops":[{"insert":"Finally, the scatter plot capability can be used to create simple drawings as shown in the following example:\n"}]}},{"type":"math","id":16,"latex":"E_{x}=\\begin{bmatrix}29.499 & 3.028 & 3.028 & 29.175 & 3.028 & 3.028 & 29.923\\end{bmatrix},\\:E_{y}=-1\\cdot\\begin{bmatrix}91.235 & 91.235 & 114.585 & 114.585 & 114.585 & 141.725 & 141.725\\end{bmatrix}","config":null},{"type":"math","id":18,"latex":"P_{x}=\\begin{bmatrix}41.233 & 66.951 & 66.873 & 41.233 & 41.233\\end{bmatrix},\\:P_{y}=-1\\cdot\\begin{bmatrix}114.585 & 114.585 & 90.985 & 90.985 & 141.725\\end{bmatrix}","config":null},{"type":"math","id":19,"latex":"X_{x}=\\begin{bmatrix}76.501 & 103.493 & 90.091 & 76.501 & 103.493\\end{bmatrix},\\:X_{y}=-1\\cdot\\begin{bmatrix}114.141 & 141.725 & 127.933 & 141.725 & 114.141\\end{bmatrix}","config":null},{"type":"math","id":20,"latex":"Y_{x}=\\begin{bmatrix}111.726 & 122.570 & 139.554 & 107.035\\end{bmatrix},\\:Y_{y}=-1\\cdot\\begin{bmatrix}114.141 & 140.914 & 114.141 & 165.402\\end{bmatrix}","config":null},{"type":"math","id":21,"latex":"Z_{x}=\\begin{bmatrix}148.048 & 172.958 & 148.048 & 172.958\\end{bmatrix},\\:Z_{y}=-1\\cdot\\begin{bmatrix}114.141 & 114.141 & 141.725 & 141.725\\end{bmatrix}","config":null},{"type":"plot","id":17,"latexs":["E_{x},E_{y}\\:as\\:lines=","P_{x},P_{y}\\:as\\:lines=","X_{x},X_{y}\\:as\\:lines=","Y_{x},Y_{y}\\:as\\:lines=","Z_{x},Z_{y}\\:as\\:lines="],"logX":false,"logY":false,"squareAspectRatio":false}],"title":"Scatter Plotting Tutorial","results":[null,[{"plot":true,"data":[{"isScatter":true,"asLines":false,"numericOutput":true,"numericInput":true,"negLogLimit":false,"limitsUnitsMatch":true,"input":[1,2,3,4,5],"output":[0.9,1.3,2.1,2.9,3.2],"inputReversed":false,"inputUnits":"","inputUnitsLatex":"","inputCustomUnitsDefined":false,"inputCustomUnits":"","inputCustomUnitsLatex":"","inputName":"x1","inputNameLatex":"x_{1}","outputUnits":"","outputUnitsLatex":"","outputCustomUnitsDefined":false,"outputCustomUnits":"","outputCustomUnitsLatex":"","outputName":"y1","outputNameLatex":"y_{1}","isParametric":false}]}],null,{"value":"","symbolicValue":"","units":"","unitsLatex":"","numeric":false,"customUnitsDefined":false,"customUn