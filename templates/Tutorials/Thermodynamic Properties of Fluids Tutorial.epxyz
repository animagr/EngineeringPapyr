true,"customUnitsDefined":false,"customUnits":"kg^1*m^-3","customUnitsLatex":"\\left\\lbrack \\frac{kg}{m^{3}}\\right\\rbrack "},{"value":"3896.198603679421466949861496686935424804687500000000000000000000","symbolicValue":"3896.19860367942","numeric":true,"units":"m^2*s^-2*K^-1","unitsLatex":"\\left\\lbrack \\frac{m^{2}}{s^{2}\\cdot K}\\right\\rbrack ","real":true,"finite":true,"customUnitsDefined":false,"customUnits":"m^2*s^-2*K^-1","customUnitsLatex":"\\left\\lbrack \\frac{m^{2}}{s^{2}\\cdot K}\\right\\rbrack "},null,null,null,null],"system_results":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],"codeCellResults":{},"sub_results":[],"nextId":35,"sheetId":"fdd9dda4-8dc5-45a6-8008-eaa75fd18398","insertedSheets":[]},"history":[{"url":"Thermodynamic Properties of Fluids Tutorial","hash":"file","creation":"2026-05-08T11:56:03.948Z"},{"url":"https://bump-pyodide.engineeringpaper.pages.dev/mWf3zkzQEmYsUPckCPX5P8","hash":"mWf3zkzQEmYsUPckCPX5P8","creation":"2024-06-11T18:53:01.920Z"},{"url":"Thermodynamic Properties of Fluids Tutorial","hash":"file","creation":"2024-06-11T18:52:45.936Z"},{"url":"https://bump-pyodide.engineeringpaper.pages.dev/k2XYDRTAMrDgrZxWcA3KqN","hash":"k2XYDRTAMrDgrZxWcA3KqN","creation":"2024-06-11T18:42:27.106Z"},{"url":"Thermodynamic Properties of Fluids Tutorial","hash":"file","creation":"2024-06-11T18:42:21.973Z"},{"url":"Thermodynamic Properties of Fluids Tutorial","hash":"file","creation":"2024-06-11T18:30:34.882Z"},{"url":"Thermodynamic Properties of Fluids Tutorial","hash":"file","creation":"2024-06-11T18:22:14.082Z"},{"url":"Thermodynamic Properties of Fluids Tutorial","hash":"file","creation":"2024-06-11T17:24:53.590Z"}]}