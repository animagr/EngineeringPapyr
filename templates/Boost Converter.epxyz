{"data":{"version":20260313,"config":{"mathCellConfig":{"symbolicOutput":false,"showIntermediateResults":false,"formatOptions":{"notation":"auto","precision":15,"lowerExp":-3,"upperExp":5}},"simplifySymbolicExpressions":true,"convertFloatsToFractions":true},"cells":[{"type":"documentation","id":0,"json":{"ops":[{"attributes":{"bold":true,"size":"large"},"insert":"Boost (Step-Up) Converter Design"},{"insert":"\n"}]}},{"type":"documentation","id":1,"json":{"ops":[{"attributes":{"bold":true},"insert":"Input Parameters"},{"insert":"\n"}]}},{"type":"math","id":2,"latex":"V_{in}=5","config":null,"annotation":"Input Voltage [V]"},{"type":"math","id":3,"latex":"V_{out}=12","config":null,"annotation":"Output Voltage [V]"},{"type":"math","id":4,"latex":"I_{out}=0.5","config":null,"annotation":"Output Current [A]"},{"type":"math","id":5,"latex":"f_{sw}=500000","config":null,"annotation":"Switching Frequency [Hz]"},{"type":"math","id":6,"latex":"I_{rip}=0.5","config":null,"annotation":"Inductor Current Ripple pk-pk [A]"},{"type":"math","id":7,"latex":"V_{rip}=0.1","config":null,"annotation":"Output Voltage Ripple pk-pk [V]"},{"type":"documentation","id":8,"json":{"ops":[{"attributes":{"bold":true},"insert":"Design Equations"},{"insert":"\n"}]}},{"type":"math","id":9,"latex":"D=1-\\frac{V_{in}}{V_{out}}=","config":null,"annotation":"Duty Cycle"},{"type":"math","id":10,"latex":"L=\\frac{V_{in}\\cdot D}{f_{sw}\\cdot I_{rip}}=","config":null,"annotation":"Min Inductance [H]"},{"type":"math","id":11,"latex":"C_{out}=\\frac{I_{out}\\cdot D}{f_{sw}\\cdot V_{rip}}=","config":null,"annotation":"Min Output Capacitance [F]"},{"type":"documentation","id":12,"json":{"ops":[{"attributes":{"bold":true},"insert":"Inductor & Switch Stress"},{"insert":"\n"}]}},{"type":"math","id":13,"latex":"I_{Lavg}=\\frac{I_{out}}{1-D}=","config":null,"annotation":"Avg Inductor Current = Input Current [A]"},{"type":"math","id":14,"latex":"I_{Lpk}=I_{Lavg}+\\frac{I_{rip}}{2}=","config":null,"annotation":"Peak I