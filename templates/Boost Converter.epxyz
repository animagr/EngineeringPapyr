{"data":{"version":20260313,"config":{"mathCellConfig":{"symbolicOutput":false,"showIntermediateResults":false,"formatOptions":{"notation":"auto","precision":5,"lowerExp":-3,"upperExp":5}},"simplifySymbolicExpressions":true,"convertFloatsToFractions":true,"customBaseUnits":{"mass":"kg","length":"m","time":"s","current":"A","temperature":"K","luminous_intensity":"cd","amount_of_substance":"mol","force":"N","area":"m^2","volume":"m^3","energy":"J","power":"W","pressure":"Pa","charge":"C","capacitance":"F","electric_potential":"V","resistance":"ohm","inductance":"H","conductance":"S","magnetic_flux":"Wb","magnetic_flux_density":"T","angle":"rad","information":"b"},"fluidConfig":{"fluid":"Water","incompMixConc":0.5,"customMixture":[{"fluid":"R32","moleFraction":0.697615},{"fluid":"R125","moleFraction":0.302385}]}},"cells":[{"type":"documentation","id":0,"json":{"ops":[{"attributes":{"size":"large","bold":true},"insert":"Boost (Step-Up) Converter Design"},{"insert":"\n"}]}},{"type":"documentation","id":1,"json":{"ops":[{"insert":"Per TI SLVA372D — Basic Calculation of a Boost Converter's Power Stage\n"}]}},{"type":"documentation","id":2,"json":{"ops":[{"attributes":{"bold":true},"insert":"Input Parameters"},{"insert":"\n"}]}},{"type":"math","id":3,"latex":"V_{in}=5","config":null,"annotation":"Typical Input Voltage [V]"},{"type":"math","id":4,"latex":"V_{inmin}=3.3","config":null,"annotation":"Min Input Voltage [V]"},{"type":"math","id":5,"latex":"V_{out}=12","config":null,"annotation":"Output Voltage [V]"},{"type":"math","id":6,"latex":"I_{outmax}=0.5","config":null,"annotation":"Max Output Current [A]"},{"type":"math","id":7,"latex":"f_{s}=500000","config":null,"annotation":"Switching Frequency [Hz]"},{"type":"math","id":8,"latex":"\\eta=0.8","config":null,"annotation":"Estimated Efficiency"},{"type":"math","id":9,"latex":"V_{F}=0.5","config":null,"annotation":"Diode Forward Voltage [V]"},{"type":"math","id":10,"latex":"V_{FB}=0.8","config":null,"annotation":"Feedback Voltage [V]"},{"type":"math","id":11,"latex":"I_{FB}=0.000001","config":null,"annotation":"Feedback Bias Current [A]"},{"type":"math","id":12,"latex":"R_{ESR}=0.02","config":null,"annotation":"Output Cap ESR [ohm]"},{"type":"math","id":13,"latex":"V_{rip}=0.1","config":null,"annotation":"Output Voltage Ripple [V]"},{"type":"documentation","id":14,"json":{"ops":[{"attributes":{"bold":true},"insert":"Duty Cycle (Eq. 1)"},{"insert":"\n"}]}},{"type":"math","id":15,"latex":"D=1-\\frac{V_{inmin}\\cdot\\eta}{V_{out}}=","config":null,"annotation":"Duty Cycle"},{"type":"documentation","id":16,"json":{"ops":[{"attributes":{"bold":true},"insert":"Inductor Selection (Eq. 5, 6)"},{"insert":"\n"}]}},{"type":"math","id":17,"latex":"I_{rip}=0.3\\cdot I_{outmax}\\cdot\\frac{V_{out}}{V_{in}}=","config":null,"annotation":"Inductor Ripple Current [A]"},{"type":"math","id":18,"latex":"L=\\frac{V_{in}\\cdot\\left(V_{out}-V_{in}\\right)}{I_{rip}\\cdot f_{s}\\cdot V_{out}}=","config":null,"annotation":"Inductance [H]"},{"type":"documentation","id":19,"json":{"ops":[{"attributes":{"bold":true},"insert":"Maximum Switch Current (Eq. 4)"},{"insert":"\n"}]}},{"type":"math","id":20,"latex":"I_{swmax}=\\frac{I_{rip}}{2}+\\frac{I_{outmax}}{1-D}=","config":null,"annotation":"Max Switch Current [A]"},{"type":"documentation","id":21,"json":{"ops":[{"attributes":{"bold":true},"insert":"Inductor Stress"},{"insert":"\n"}]}},{"type":"math","id":22,"latex":"I_{Lavg}=\\frac{I_{outmax}}{1-D}=","config":null,"annotation":"Avg Inductor Current [A]"},{"type":"math","id":23,"latex":"I_{Lpk}=I_{Lavg}+\\frac{I_{rip}}{2}=","config":null,"annotation":"Peak Inductor Current [A]"},{"type":"math","id":24,"latex":"I_{Lrms}=\\sqrt{I_{Lavg}^{2}+\\frac{I_{rip}^{2}}{12}}=","config":null,"annotation":"RMS Inductor Current [A]"},{"type":"documentation","id":25,"json":{"ops":[{"attributes":{"bold":true},"insert":"Rectifier Diode Selection (Eq. 7, 8)"},{"insert":"\n"}]}},{"type":"math","id":26,"latex":"I_{F}=I_{outmax}=","config":null,"annotation":"Diode Avg Forward Current [A]"},{"type":"math","id":27,"latex":"P_{D}=I_{F}\\cdot V_{F}=","config":null,"annotation":"Diode Power Dissipation [W]"},{"type":"documentation","id":28,"json":{"ops":[{"attributes":{"bold":true},"insert":"Output Voltage Setting (Eq. 9-11)"},{"insert":"\n"}]}},{"type":"math","id":29,"latex":"I_{div}=100\\cdot I_{FB}=","config":null,"annotation":"Divider Current [A]"},{"type":"math","id":30,"latex":"R_{2}=\\frac{V_{FB}}{I_{div}}=","config":null,"annotation":"Bottom FB Resistor [ohm]"},{"type":"math","id":31,"latex":"R_{1}=R_{2}\\cdot\\left(\\frac{V_{out}}{V_{FB}}-1\\right)=","config":null,"annotation":"Top FB Resistor [ohm]"},{"type":"documentation","id":32,"json":{"ops":[{"attributes":{"bold":true},"insert":"Output Capacitor Selection (Eq. 12, 13)"},{"insert":"\n"}]}},{"type":"math","id":33,"latex":"C_{out}=\\frac{I_{outmax}\\cdot D}{f_{s}\\cdot V_{rip}}=","config":null,"annotation":"Min Output Capacitance [F]"},{"type":"math","id":34,"latex":"V_{ripESR}=R_{ESR}\\cdot\\left(\\frac{I_{outmax}}{1-D}+\\frac{I_{rip}}{2}\\right)=","config":null,"annotation":"ESR Voltage Ripple [V]"},{"type":"documentation","id":35,"json":{"ops":[{"attributes":{"bold":true},"insert":"CCM Boundary"},{"insert":"\n"}]}},{"type":"math","id":36,"latex":"L_{min}=\\frac{V_{inmin}\\cdot D\\cdot\\left(1-D\\right)}{2\\cdot f_{s}\\cdot I_{outmax}}=","config":null,"annotation":"Min L for CCM [H]"}],"title":"Boost Converter Design (SLVA372D)","results":[null,null,null,{"value":"","symbolicValue":"","units":"","unitsLatex":"","numeric":false,"customUnitsDefined":false,"customUnits":"","customUnitsLatex":"","real":false,"finite":false,"isSubResult":false,"subQueryName":""},{"value":"","symbolicValue":"","units":"","unitsLatex":"","numeric":false,"customUnitsDefined":false,"customUnits":"","customUnitsLatex":"","real":false,"finite":false,"isSubResult":false,"subQueryName":""},{"value":"","symbolicValue":"","units":"","unitsLatex":"","numeric":false,"cust