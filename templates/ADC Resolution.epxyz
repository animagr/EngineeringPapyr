{"data":{"version":20260313,"config":{"mathCellConfig":{"symbolicOutput":false,"showIntermediateResults":false,"formatOptions":{"notation":"auto","precision":5,"lowerExp":-3,"upperExp":5}},"simplifySymbolicExpressions":true,"convertFloatsToFractions":true,"customBaseUnits":{"mass":"kg","length":"m","time":"s","current":"A","temperature":"K","luminous_intensity":"cd","amount_of_substance":"mol","force":"N","area":"m^2","volume":"m^3","energy":"J","power":"W","pressure":"Pa","charge":"C","capacitance":"F","electric_potential":"V","resistance":"ohm","inductance":"H","conductance":"S","magnetic_flux":"Wb","magnetic_flux_density":"T","angle":"rad","information":"b"},"fluidConfig":{"fluid":"Water","incompMixConc":0.5,"customMixture":[{"fluid":"R32","moleFraction":0.697615},{"fluid":"R125","moleFraction":0.302385}]}},"cells":[{"type":"documentation","id":0,"json":{"ops":[{"attributes":{"size":"large","bold":true},"insert":"ADC Resolution vs. Accuracy Analysis"},{"insert":"\n"}]}},{"type":"documentation","id":1,"json":{"ops":[{"insert":"Per TI SLAA587 — ADC Performance Parameters.\n"}]}},{"type":"documentation","id":2,"json":{"ops":[{"attributes":{"bold":true},"insert":"Input Parameters"},{"insert":"\n"}]}},{"type":"math","id":3,"latex":"N=16","config":null,"annotation":"ADC Resolution [bits]"},{"type":"math","id":4,"latex":"V_{FS}=5","config":null,"annotation":"Full-Scale Voltage [V]"},{"type":"documentation","id":5,"json":{"ops":[{"attributes":{"bold":true},"insert":"Resolution"},{"insert":"\n"}]}},{"type":"math","id":6,"latex":"V_{LSB}=\\frac{V_{FS}}{2^{N}}=","config":null,"annotation":"Voltage per LSB [V]"},{"type":"math","id":7,"latex":"N_{lev}=2^{N}=","config":null,"annotation":"Quantization Levels"},{"type":"documentation","id":8,"json":{"ops":[{"attributes":{"bold":true},"insert":"Offset (Zero) Error"},{"insert":"\n"}]}},{"type":"documentation","id":9,"json":{"ops":[{"insert":"Constant shift of the ADC transfer function from ideal. Also called zero scale error. Specified as %FSR (SLAA587 §2.1).\n"}]}},{"type":"math","id":10,"latex":"ofs=0.04","config":null,"annotation":"Offset Error [%FSR]"},{"type":"math","id":11,"latex":"ofs_{V}=\\frac{ofs}{100}\\cdot V_{FS}=","config":null,"annotation":"Offset Error [V]"},{"type":"math","id":12,"latex":"ofs_{LSB}=\\frac{ofs_{V}}{V_{LSB}}=","config":null,"annotation":"Offset Error [LSB]"},{"type":"documentation","id":13,"json":{"ops":[{"attributes":{"bold":true},"insert":"Gain (Full Scale) Error"},{"insert":"\n"}]}},{"type":"documentation","id":14,"json":{"ops":[{"insert":"Deviation in slope of the transfer function. Difference between ideal and actual voltage producing full-scale output code (SLAA587 §2.2).\n"}]}},{"type":"math","id":15,"latex":"gn=.05","config":null,"annotation":"Gain Error [%FSR]"},{"type":"math","id":16,"latex":"gn_{V}=\\frac{gn}{100}\\cdot V_{FS}=","config":null,"annotation":"Gain Error [V]"},{"type":"math","id":17,"latex":"gn_{LSB}=\\frac{gn_{V}}{V_{LSB}}=","config":null,"annotation":"Gain Error [LSB]"},{"type":"documentation","id":18,"json":{"ops":[{"attributes":{"bold":true},"insert":"Nonlinearity Errors"},{"insert":"\n"}]}},{"type":"documentation","id":19,"json":{"ops":[{"insert":"DNL: deviation of any single code width from ideal 1 LSB step. INL: cumulative deviation of the transfer function from a straight line (SLAA587 §2.3–2.4).\n"}]}},{"type":"math","id":20,"latex":"INL=4","config":null,"annotation":"Integral Nonlinearity [LSB]"},{"type":"math","id":21,"latex":"DNL=1","config":null,"annotation":"Differential Nonlinearity [LSB]"},{"type":"documentation","id":22,"json":{"ops":[{"attributes":{"bold":true},"insert":"Total Unadjusted Error (TUE) at 25°C"},{"insert":"\n"}]}},{"type":"documentation","id":23,"json":{"ops":[{"insert":"TUE is the worst-case RMS error without calibration. RSS of all static errors (SLAA587 §2.5).\n"}]}},{"type":"math","id":24,"latex":"TUE=\\sqrt{ofs_{LSB}^{2}+gn_{LSB}^{2}+INL^{2}+DNL^{2}}=","config":null,"annotation":"Total Unadjusted Error [LSB]"},{"type":"documentation","id":25,"json":{"ops":[{"attributes":{"bold":true},"insert":"Temperature Drift"},{"insert":"\n"}]}},{"type":"documentation","id":26,"json":{"ops":[{"insert":"Offset and gain errors vary with temperature. Drift is ppm/°C of V_FS. Error at temp = error at 25°C + drift × ΔT × V_FS (SLAA587 §2.1–2.2).\n"}]}},{"type":"math","id":27,"latex":"d_{ofs}=0.5","config":null,"annotation":"Offset Drift [ppm/°C]"},{"type":"math","id":28,"latex":"d_{gn}=1","config":null,"annotation":"Gain Drift [ppm/°C]"},{"type":"math","id":29,"latex":"T_{max}=85","config":null,"annotation":"Max Operating Temp [°C]"},{"type":"math","id":30,"latex":"T_{ref}=25","config":null,"annotation":"Reference Temp [°C]"},{"type":"math","id":31,"latex":"dT=T_{max}-T_{ref}=","config":null,"annotation":"Temperature Delta [°C]"},{"type":"math","id":32,"latex":"D_{ofsV}=\\frac{d_{ofs}}{10^{6}}\\cdot dT\\cdot V_{FS}=","config":null,"annotation":"Offset Drift Voltage [V]"},{"type":"math","id":33,"latex":"D_{gnV}=\\frac{d_{gn}}{10^{6}}\\cdot dT\\cdot V_{FS}=","config":null,"annotation":"Gain Drift Voltage [V]"},{"type":"documentation","id":34,"json":{"ops":[{"attributes":{"bold":true},"insert":"Total Errors Including Temperature Drift"},{"insert":"\n"}]}},{"type":"math","id":35,"latex":"ofs_{TV}=ofs_{V}+D_{ofsV}=","config":null,"annotation":"Total Offset Error with Drift [V]"},{"type":"math","id":36,"latex":"gn_{TV}=gn_{V}+D_{gnV}=","config":null,"annotation":"Total Gain Error with Drift [V]"},{"type":"math","id":37,"latex":"ofs_{TL}=\\frac{ofs_{TV}}{V_{LSB}}=","config":null,"annotation":"Total Offset Error with Drift [LSB]"},{"type":"math","id":38,"latex":"gn_{TL}=\\frac{gn_{TV}}{V_{LSB}}=","config":null,"annotation":"Total Gain Error with Drift [LSB]"},{"type":"documentation","id":39,"json":{"ops":[{"attributes":{"bold":true},"insert":"TUE with Temperature Drift"},{"insert":"\n"}]}},{"type":"math","id":40,"latex":"TUE_{T}=\\sqrt{ofs_{TL}^{2}+gn_{TL}^{2}+INL^{2}+DNL^{2}}=","config":null,"annotation":"TUE with Drift [LSB]"},{"type":"documentation","id":41,"json":{"ops":[{"attributes":{"bold":true},"insert":"Effective Number of Bits (ENOB)"},{"insert":"\n"}]}},{"type":"documentation","id":42,"json":{"ops":[{"insert":"Effective accuracy in bits accounts for all error sources. ENOB = N - log2(TUE). A 12-bit ADC with large errors may only deliver a few effective bits.\n"}]}},{"type":"math","id":43,"latex":"e_{q}=0.5","config":null,"annotation":"Quantization Error [LSB]"},{"type":"math","id":44,"latex":"ENOB_{T}=N-\\frac{\\ln\\left(TUE_{T}\\right)}{\\ln\\left(2\\right)}=","config":null,"annotation":"Effective Bits with Drift"},{"type":"math","id":45,"latex":"V_{resT}=\\frac{V_{FS}}{2^{ENOB_{T}}}=","config":null,"annotation":"Effective Voltage Resolution [V]"},{"type":"math","id":46,"latex":"V_{rTmV}=V_{resT}\\cdot1000=","config":null,"annotation":"Effective Voltage Resolution [mV]"},{"type":"documentation","id":47,"json":{"ops":[{"attributes":{"bold":true},"insert":"After Calibrating Out Offset and Gain Errors"},{"insert":"\n"}]}},{"type":"documentation","id":48,"json":{"ops":[{"insert":"Offset and gain errors can be removed via calibration. Remaining error is dominated by INL and DNL (SLAA587 §2.5).\n"}]}},{"type":"math","id":49,"latex":"TUE_{cal}=\\sqrt{INL^{2}+DNL^{2}}=","config":null,"annotation":"Calibrated TUE [LSB]"},{"type":"math","id":50,"latex":"ENOB_{cal}=N-\\frac{\\ln\\left(TUE_{cal}\\right)}{\\ln\\left(2\\right)}=","config":null,"annotation":"Effective Bits after Calibration"},{"type":"math","id":51,"latex":"V_{rescal}=\\frac{V_{FS}}{2^{ENOB_{cal}}}=","config":null,"annotation":"Calibrated Voltage Resolution [V]"},{"type":"math","id":52,"latex":"V_{rcmV}=V_{rescal}\\cdot1000=","config":null,"annotation":"Calibrated Voltage Resolution [mV]"}],"title":"ADC Resolution vs. Accuracy Analysis (SLAA587)","results":[null,null,null,{"value":"","symbolicValue":"","units":"","unitsLatex":"","numeric":false,"customUnitsDefined":false,"customUnits":